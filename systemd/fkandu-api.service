[Unit]
Description=FKandu Dashboard API (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/BotsRepo/fkandu_manager_bot/dashboard/backend
EnvironmentFile=/root/BotsRepo/fkandu_manager_bot/.env
EnvironmentFile=/root/BotsRepo/deploy/ports.env
ExecStart=/usr/bin/python3 -m uvicorn api:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
