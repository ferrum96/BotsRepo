# GitHub Webhook settings (HTTP, preferred when ufw allows the port):
# - URL: http://YOUR_SERVER_IP:450/
# - Content type: application/json
# - Events: Push + Pull requests
# - Secret: same as WEBHOOK_SECRET below
#
# Optional HTTPS via Caddy:
# - URL: https://YOUR_GATEWAY_DOMAIN/hooks/deploy
WEBHOOK_SECRET=changeme
