# Optional domains for Caddy setup script (static IP friendly).
# Copy to deploy/domains.env and adjust values.
#
# Main gateway domain. If empty, pass it via:
#   --gateway-domain your.domain
# or:
#   --subdomain your-duckdns-name
#
# GATEWAY_DOMAIN="mybots.duckdns.org"
#
# Per-service dedicated domains (optional).
# If set, Caddy creates additional host-based reverse proxy blocks.
# Leave empty to use only path-based routing on GATEWAY_DOMAIN.

GATEWAY_DOMAIN="fkandu.duckdns.org"
SERVICE_DOMAIN_FKANDU="fkandu.duckdns.org"
SERVICE_DOMAIN_KANBAN="kanban-board.duckdns.org"
SERVICE_DOMAIN_BB_CLAN="bb-clan.duckdns.org"
