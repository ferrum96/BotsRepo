# Карта портов BotsRepo (production VPS, systemd).
# Публичные порты nginx (444–448) — НЕ МЕНЯТЬ, уже заняты на сервере.

# --- Публичные (nginx listen) ---
PORT_FKANDU_DASHBOARD_PUBLIC=444
PORT_FKANDU_API_PUBLIC=445
PORT_FKANDU_BOT_PUBLIC=446
PORT_PUBG_DASHBOARD_PUBLIC=447
PORT_KANBAN_PUBLIC=448

# --- Внутренние (systemd на localhost) ---
# fkandu-dashboard (Next.js standalone)
PORT_FKANDU_DASHBOARD=3000
# fkandu-api (FastAPI)
PORT_FKANDU_API=8000
# fkandu-bot файловый сервер
PORT_FKANDU_BOT_FILES=8088
# kanban (Hono) — 3000 занят fkandu-dashboard
PORT_KANBAN=3002
# pubg-api (FastAPI + SPA)
PORT_PUBG_API=8080

# Webhook деплоя (localhost; снаружи nginx :450 + ufw; опционально Caddy /hooks/deploy)
PORT_DEPLOY_WEBHOOK=9000
PORT_DEPLOY_WEBHOOK_PUBLIC=450
DEPLOY_WEBHOOK_PATH=/hooks/deploy

# --- Development (localhost, не пересекаются с production) ---
# Можно запускать dev-стеки параллельно с systemd на том же хосте.
PORT_DEV_FKANDU_DASHBOARD=3010
PORT_DEV_FKANDU_API=8010
PORT_DEV_KANBAN_SERVER=3001
PORT_DEV_KANBAN_VITE=5173
PORT_DEV_PUBG_VITE=5174
PORT_DEV_PUBG_API=8081
