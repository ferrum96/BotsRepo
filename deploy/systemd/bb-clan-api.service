[Unit]
Description=BB Clan Dashboard API (FastAPI + SPA)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/BotsRepo/bb_clan_moderator_bot
EnvironmentFile=/root/BotsRepo/bb_clan_moderator_bot/.env
EnvironmentFile=/root/BotsRepo/deploy/ports.env
Environment=DATABASE_PATH=/root/BotsRepo/bb_clan_moderator_bot/data/bot.db
Environment=DASHBOARD_PORT=8080
ExecStart=/usr/bin/python3 -m dashboard.backend.run
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
